{% extends "admin/base.html" %}
{% load static %}

{% block title %}{{ title }} | {{ site_header|default:"JKR Admin" }}{% endblock %}

{% block extrahead %}
    {{ block.super }}
    <link rel="stylesheet" href="{% static 'admin/css/admin_premium.css' %}">
    <script src="{% static 'admin/js/admin_ux.js' %}"></script>
    <style>
        /* Minimal site-wide tweaks */
        #branding h1 { display: flex; align-items: center; }
        #branding h1::before { content: '🏬'; margin-right: 15px; font-size: 1.8rem; }
    </style>
{% endblock %}

{% block branding %}
<h1 id="site-name"><a href="{% url 'admin:index' %}">{{ site_header|default:"JKR International" }}</a></h1>
{% endblock %}

{% block breadcrumbs %}
<div class="breadcrumbs">
<a href="{% url 'admin:index' %}">Home</a>
{% if title %} &rsaquo; {{ title }}{% endif %}
</div>
{% endblock %}
